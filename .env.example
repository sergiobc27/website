# Local-only values. Do not commit real secrets.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional Worker secret, configured with:
# npx wrangler secret put SOCRATA_APP_TOKEN
SOCRATA_APP_TOKEN=

# Optional smoke-test target.
IDEAM_BASE_URL=https://ideam.sergiobc.com

# Cloudflare Turnstile: clave PÚBLICA del widget (frontend). El secret
# (TURNSTILE_SECRET_KEY) va como secreto del Worker, no aquí.
VITE_TURNSTILE_SITE_KEY=
