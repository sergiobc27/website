{
  "name": "ideam-sergiobc-website",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "React frontend and Cloudflare Worker API for ideam.sergiobc.com",
  "scripts": {
    "build": "vite build",
    "check": "node --check src/worker/index.js",
    "check:worker": "node --check src/worker/index.js",
    "typecheck": "tsc --noEmit",
    "dev:web": "vite",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "e2e": "playwright test",
    "e2e:prod": "playwright test tests/e2e/ideam-production.spec.ts",
    "postinstall": "node scripts/patch-parquetjs-lite.mjs",
    "warm:catalogs": "node scripts/warm-catalog-bundles.mjs",
    "tail": "wrangler tail",
    "test": "node --test tests/worker.test.mjs",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@types/katex": "^0.16.8",
    "class-variance-authority": "^0.7.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "lucide-react": "0.487.0",
    "maplibre-gl": "^5.24.0",
    "parquetjs-lite": "^0.8.7",
    "pdf-lib": "^1.17.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.15.2",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "4.1.12",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.6",
    "wrangler": "^4.95.0"
  }
}
