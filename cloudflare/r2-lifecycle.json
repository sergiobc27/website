{
  "rules": [
    {
      "id": "delete-async-exports-after-1-hour",
      "enabled": true,
      "conditions": {
        "prefix": "exports/"
      },
      "deleteObjectsTransition": {
        "condition": {
          "type": "Age",
          "maxAge": 3600
        }
      }
    },
    {
      "id": "expire-stale-catalog-cache-after-2-days",
      "enabled": true,
      "conditions": {
        "prefix": "catalog-cache/"
      },
      "deleteObjectsTransition": {
        "condition": {
          "type": "Age",
          "maxAge": 172800
        }
      }
    }
  ]
}
